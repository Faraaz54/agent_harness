{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Review Result",
  "type": "object",
  "required": [
    "schema_version",
    "review_type",
    "reviewer",
    "task_id",
    "attempt",
    "verdict",
    "active_skills",
    "files_reviewed",
    "dimensions_reviewed",
    "criteria_matrix",
    "findings",
    "model_routing"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "review_type": {
      "enum": [
        "test",
        "principal_engineering",
        "delivery",
        "generic_review"
      ]
    },
    "reviewer": {
      "enum": [
        "test-agent",
        "principal-engineer-agent",
        "delivery-agent",
        "reviewer"
      ]
    },
    "task_id": {
      "type": "string"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "verdict": {
      "enum": [
        "PASS",
        "APPROVE",
        "CHANGES_REQUIRED",
        "BLOCKED",
        "BLOCKED_BY_ENVIRONMENT",
        "BLOCKED_BY_MISSING_TEST_TIER"
      ]
    },
    "active_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dimensions_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "status",
          "evidence"
        ],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_APPLICABLE",
              "MISSING",
              "UNKNOWN"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "finding_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "negative_case_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case",
          "status",
          "evidence"
        ],
        "properties": {
          "case": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_APPLICABLE",
              "MISSING",
              "UNKNOWN"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "finding_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "tier_evidence_matrix": {
      "type": "object",
      "properties": {
        "unit": {
          "type": "object"
        },
        "integration": {
          "type": "object"
        },
        "local_e2e": {
          "type": "object"
        },
        "cloud_e2e": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "contract_completeness": {
      "type": "object",
      "properties": {
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "NOT_APPLICABLE"
          ]
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "commands_inspected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status"
        ],
        "properties": {
          "command": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "SKIPPED",
              "NOT_RUN",
              "BLOCKED"
            ]
          },
          "returncode": {
            "type": [
              "integer",
              "null"
            ]
          },
          "summary": {
            "type": "string"
          },
          "evidence_path": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "coverage_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "false_positive_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "title",
          "problem",
          "required_outcome",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "INFO",
              "MINOR",
              "MAJOR",
              "CRITICAL",
              "BLOCKER"
            ]
          },
          "title": {
            "type": "string"
          },
          "problem": {
            "type": "string"
          },
          "required_outcome": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "string"
          },
          "suggested_test": {
            "type": "string"
          },
          "repair_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocks_completion": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "model_routing": {
      "type": "object",
      "properties": {
        "alias": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_model": {
          "type": "string"
        },
        "reasoning_effort": {
          "type": "string"
        },
        "fallback_used": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
