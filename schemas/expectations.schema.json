{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "acceptance_criteria": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "failure_scenarios": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "intent_id": {
      "minLength": 1,
      "type": "string"
    },
    "negative_cases": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "private_eval_boundary": {
      "type": "object"
    },
    "required_testing_tiers": {
      "additionalProperties": false,
      "properties": {
        "cloud_e2e": {
          "additionalProperties": false,
          "properties": {
            "reason": {
              "minLength": 1,
              "type": "string"
            },
            "required": {
              "type": "boolean"
            }
          },
          "required": [
            "required",
            "reason"
          ],
          "type": "object"
        },
        "integration": {
          "additionalProperties": false,
          "properties": {
            "reason": {
              "minLength": 1,
              "type": "string"
            },
            "required": {
              "type": "boolean"
            }
          },
          "required": [
            "required",
            "reason"
          ],
          "type": "object"
        },
        "local_e2e": {
          "additionalProperties": false,
          "properties": {
            "reason": {
              "minLength": 1,
              "type": "string"
            },
            "required": {
              "type": "boolean"
            }
          },
          "required": [
            "required",
            "reason"
          ],
          "type": "object"
        },
        "unit": {
          "additionalProperties": false,
          "properties": {
            "reason": {
              "minLength": 1,
              "type": "string"
            },
            "required": {
              "type": "boolean"
            }
          },
          "required": [
            "required",
            "reason"
          ],
          "type": "object"
        }
      },
      "required": [
        "unit",
        "integration",
        "local_e2e",
        "cloud_e2e"
      ],
      "type": "object"
    },
    "review_requirements": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "type": "string"
    },
    "source_context_id": {
      "type": "string"
    },
    "stop_conditions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "success_scenarios": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "testing_expectations_matrix": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "behavior_or_risk": {
            "minLength": 1,
            "type": "string"
          },
          "cloud_e2e": {
            "minLength": 1,
            "type": "string"
          },
          "integration": {
            "minLength": 1,
            "type": "string"
          },
          "local_e2e": {
            "minLength": 1,
            "type": "string"
          },
          "unit": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "behavior_or_risk",
          "unit",
          "integration",
          "local_e2e",
          "cloud_e2e"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "validation_strategy": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "intent_id",
    "success_scenarios",
    "failure_scenarios",
    "acceptance_criteria",
    "validation_strategy",
    "testing_expectations_matrix",
    "required_testing_tiers"
  ],
  "title": "IDSD Expectations",
  "type": "object"
}
