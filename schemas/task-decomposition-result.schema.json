{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "agent": {
      "const": "task-decomposition-agent"
    },
    "artifacts": {
      "additionalProperties": false,
      "properties": {
        "task_contracts_json": {
          "type": "string"
        }
      },
      "required": [
        "task_contracts_json"
      ],
      "type": "object"
    },
    "context_files_considered": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "applied_to": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "context_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "context_id",
          "path",
          "applied_to"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "epics": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "findings": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "intent_id": {
      "type": "string"
    },
    "model_routing": {
      "type": "object"
    },
    "schema_version": {
      "type": "string"
    },
    "tasks": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "technical_spec_considered": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "sections_used": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "spec_id": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "spec_id",
        "sections_used"
      ],
      "type": "object"
    },
    "verdict": {
      "enum": [
        "PASS",
        "CHANGES_REQUIRED",
        "BLOCKED_BY_AMBIGUITY",
        "BLOCKED_BY_MISSING_CONTEXT"
      ]
    }
  },
  "required": [
    "schema_version",
    "agent",
    "intent_id",
    "verdict",
    "artifacts",
    "epics",
    "tasks",
    "model_routing",
    "context_files_considered",
    "technical_spec_considered"
  ],
  "title": "Task Decomposition Result",
  "type": "object"
}
