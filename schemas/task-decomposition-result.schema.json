{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "agent": {
      "const": "task-decomposition-agent"
    },
    "artifacts": {
      "additionalProperties": false,
      "properties": {
        "task_contracts_json": {
          "type": "string"
        }
      },
      "required": [
        "task_contracts_json"
      ],
      "type": "object"
    },
    "epics": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "findings": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "intent_id": {
      "type": "string"
    },
    "model_routing": {
      "type": "object"
    },
    "schema_version": {
      "type": "string"
    },
    "tasks": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "verdict": {
      "enum": [
        "PASS",
        "CHANGES_REQUIRED",
        "BLOCKED_BY_AMBIGUITY",
        "BLOCKED_BY_MISSING_CONTEXT"
      ]
    }
  },
  "required": [
    "schema_version",
    "agent",
    "intent_id",
    "verdict",
    "artifacts",
    "epics",
    "tasks",
    "model_routing"
  ],
  "title": "Task Decomposition Result",
  "type": "object"
}
