{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acceptance_criteria": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "criterion": {
            "type": "string"
          },
          "evidence": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "finding_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "MISSING",
              "NOT_APPLICABLE"
            ]
          }
        },
        "required": [
          "criterion",
          "status",
          "evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "artifact_identity_checks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "artifact": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "MISSING",
              "STALE"
            ]
          }
        },
        "required": [
          "artifact",
          "status"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "attempt": {
      "minimum": 1,
      "type": "integer"
    },
    "context_coverage": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "context_id": {
            "type": "string"
          },
          "evidence": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "MISSING",
              "NOT_APPLICABLE"
            ]
          }
        },
        "required": [
          "context_id",
          "status",
          "evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "evidence_ledger_entries": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "invariant_matrix": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "evidence": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "finding_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "invariant": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "MISSING",
              "NOT_APPLICABLE"
            ]
          }
        },
        "required": [
          "invariant",
          "status",
          "evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "missing_evidence": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "model_routing": {
      "additionalProperties": true,
      "properties": {
        "alias": {
          "type": [
            "string",
            "null"
          ]
        },
        "fallback_used": {
          "type": "boolean"
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "reasoning_effort": {
          "type": "string"
        },
        "selected_model": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "negative_cases": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "case": {
            "type": "string"
          },
          "evidence": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "finding_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "MISSING",
              "NOT_APPLICABLE"
            ]
          }
        },
        "required": [
          "case",
          "status",
          "evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "review_status": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "reviewer": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "APPROVE",
              "CHANGES_REQUIRED",
              "BLOCKED",
              "MISSING"
            ]
          }
        },
        "required": [
          "reviewer",
          "status",
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "1.0"
    },
    "task_id": {
      "type": "string"
    },
    "unresolved_findings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "blocks_completion": {
            "type": "boolean"
          },
          "evidence": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "id": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "problem": {
            "type": "string"
          },
          "repair_scope": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "required_outcome": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "INFO",
              "MINOR",
              "MAJOR",
              "CRITICAL",
              "BLOCKER"
            ]
          },
          "suggested_test": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "severity",
          "title",
          "problem",
          "required_outcome",
          "evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "validator": {
      "const": "validator-agent"
    },
    "verdict": {
      "enum": [
        "PASS",
        "REJECT",
        "BLOCKED"
      ]
    }
  },
  "required": [
    "schema_version",
    "validator",
    "task_id",
    "attempt",
    "verdict",
    "context_coverage",
    "artifact_identity_checks",
    "acceptance_criteria",
    "negative_cases",
    "invariant_matrix",
    "review_status",
    "unresolved_findings",
    "missing_evidence",
    "evidence_ledger_entries",
    "model_routing"
  ],
  "title": "Task Validation Result",
  "type": "object"
}
