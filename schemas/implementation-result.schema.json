{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "active_skills": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "agent": {
      "const": "build-agent"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "attempt": {
      "minimum": 1,
      "type": "integer"
    },
    "commands_run": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "command": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            ]
          },
          "evidence_path": {
            "type": "string"
          },
          "returncode": {
            "type": [
              "integer",
              "null"
            ]
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "SKIPPED",
              "NOT_RUN",
              "BLOCKED"
            ]
          },
          "summary": {
            "type": "string"
          }
        },
        "required": [
          "command",
          "status"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "context_files_used": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "context_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "used_for": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "context_id",
          "path",
          "used_for"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "files_changed": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "files_read_before_write": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "green_evidence": {
      "additionalProperties": false,
      "properties": {
        "evidence_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "BLOCKED",
            "NOT_RUN"
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "summary"
      ],
      "type": "object"
    },
    "learning": {
      "additionalProperties": false,
      "properties": {
        "ledger_path": {
          "type": "string"
        },
        "repair_memory_candidates": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "summary"
      ],
      "type": "object"
    },
    "model_routing": {
      "additionalProperties": true,
      "properties": {
        "alias": {
          "type": [
            "string",
            "null"
          ]
        },
        "fallback_used": {
          "type": "boolean"
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "reasoning_effort": {
          "type": "string"
        },
        "selected_model": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "red_evidence": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "evidence_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "not_feasible_reason": {
          "type": "string"
        },
        "status": {
          "enum": [
            "FAILED_AS_EXPECTED",
            "NOT_FEASIBLE",
            "NOT_REQUIRED",
            "BLOCKED"
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "summary"
      ],
      "type": "object"
    },
    "residual_concerns": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "1.0"
    },
    "task_id": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "IMPLEMENTED_AWAITING_REVIEW",
        "BLOCKED"
      ]
    }
  },
  "required": [
    "schema_version",
    "agent",
    "task_id",
    "attempt",
    "verdict",
    "active_skills",
    "context_files_used",
    "files_read_before_write",
    "files_changed",
    "red_evidence",
    "green_evidence",
    "commands_run",
    "assumptions",
    "residual_concerns",
    "learning",
    "model_routing"
  ],
  "title": "Implementation Result",
  "type": "object"
}
