{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Contracts",
  "type": "object",
  "required": [
    "schema_version",
    "intent_id",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "objective",
          "behavior",
          "scope",
          "acceptance_criteria",
          "verification",
          "required_reviewers",
          "risk_level",
          "test_expectations"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "epic_id": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "behavior": {
            "type": "string"
          },
          "scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "non_goals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "negative_cases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verification": {
            "type": "object"
          },
          "required_reviewers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_level": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "test_expectations": {
            "type": "object",
            "required": [
              "highest_required_tier",
              "tier_rationale",
              "unit",
              "integration",
              "local_e2e",
              "cloud_e2e"
            ],
            "properties": {
              "highest_required_tier": {
                "enum": [
                  "unit",
                  "integration",
                  "local_e2e",
                  "cloud_e2e"
                ]
              },
              "tier_rationale": {
                "type": "string"
              },
              "unit": {
                "type": "object",
                "required": [
                  "required",
                  "what_to_test",
                  "evidence_required"
                ],
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "what_to_test": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "evidence_required": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "not_required_reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "integration": {
                "type": "object",
                "required": [
                  "required",
                  "what_to_test",
                  "evidence_required"
                ],
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "what_to_test": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "evidence_required": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "not_required_reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "local_e2e": {
                "type": "object",
                "required": [
                  "required",
                  "what_to_test",
                  "evidence_required"
                ],
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "what_to_test": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "evidence_required": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "not_required_reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "cloud_e2e": {
                "type": "object",
                "required": [
                  "required",
                  "what_to_test",
                  "evidence_required"
                ],
                "properties": {
                  "required": {
                    "type": "boolean"
                  },
                  "what_to_test": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "evidence_required": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "not_required_reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "coverage_map": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "criterion",
                    "tiers"
                  ],
                  "properties": {
                    "criterion": {
                      "type": "string"
                    },
                    "tiers": {
                      "type": "array",
                      "items": {
                        "enum": [
                          "unit",
                          "integration",
                          "local_e2e",
                          "cloud_e2e"
                        ]
                      }
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
